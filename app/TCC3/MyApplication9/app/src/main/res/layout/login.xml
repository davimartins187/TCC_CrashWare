<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <!-- BOTÃO FECHAR (X) -->
    <!-- (Você pode trocar por ImageView se quiser o ícone real) -->
    <TextView
        android:id="@+id/txtFechar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="X"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- LOGO SUPERIOR -->
    <ImageView
        android:id="@+id/imgLogo2"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:contentDescription="Logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/logo_sem_fundo" />

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ENTRAR"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toBottomOf="@id/imgLogo2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- LOGIN -->
    <EditText
        android:id="@+id/txtLogin"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:hint="E-mail ou nome de usuário"
        android:inputType="text"
        android:textColorHint="#000000"
        android:padding="16dp"
        android:background="@android:drawable/edit_text"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/txtTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SENHA -->
    <EditText
        android:id="@+id/txtSenha"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:hint="Senha"
        android:inputType="textPassword"
        android:textColorHint="#000000"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txtLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ESQUECEU SENHA -->
    <Button
        android:id="@+id/btnEsqueci"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Esqueceu?"
        android:textAllCaps="false"
        android:backgroundTint="#FFFFFF"
        android:textColor="#666666"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/txtSenha"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BOTÃO LOGIN -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Entrar"
        android:textAllCaps="false"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:backgroundTint="#5AC17A"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnEsqueci"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- OU -->
    <TextView
        android:id="@+id/txt1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ou"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnLogin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- NÃO TEM CONTA -->

    <!-- CRIAR CONTA -->

    <!-- TERMOS -->

    <TextView
        android:id="@+id/txtCadastro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Criar conta"
        android:textColor="#39C150"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/txt2"
        app:layout_constraintStart_toEndOf="@id/txt2" />

    <TextView
        android:id="@+id/txt2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="84dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="8dp"
        android:text="Não tem uma conta?"
        android:textColor="#000000"
        app:layout_constraintEnd_toStartOf="@+id/txtCadastro"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt1" />

    <TextView
        android:id="@+id/txt4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Ao entrar no Mycourse, você concorda com os nossos termos e políticas de privacidade"
        android:textAlignment="center"
        android:textStyle="italic"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/txt2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>